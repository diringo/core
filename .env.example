# Branding (rebrand for your own deployment)
NUXT_PUBLIC_BRAND_NAME=Diringo
NUXT_PUBLIC_BRAND_URL=https://diringo.com
NUXT_PUBLIC_BRAND_YEAR=2026

# STUN servers (comma-separated)
NUXT_PUBLIC_STUN_SERVERS=stun:stun.cloudflare.com:3478

# TURN relay servers (comma-separated) — optional, for NAT traversal
NUXT_PUBLIC_TURN_SERVERS=
NUXT_PUBLIC_TURN_USERNAME=
NUXT_PUBLIC_TURN_CREDENTIAL=

# PostgreSQL database (for analytics and feedback)
DATABASE_URL="postgresql://user:password@host:5432/diringo"
